# Banco de dados MySQL/MariaDB - locacao_veiculos
# Copie para .env e preencha. NUNCA use senha fixa no código.
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=locacao_veiculos

# Opcional: API (backend)
# SECRET_KEY=seu_segredo_forte
# API_USER=admin
# API_PASSWORD=admin
